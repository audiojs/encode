{
  "name": "@audio/encode-aac",
  "version": "1.1.1",
  "description": "Encode PCM audio samples to AAC (ADTS) via WebCodecs",
  "type": "module",
  "main": "aac-encode.js",
  "types": "aac-encode.d.ts",
  "exports": {
    ".": "./aac-encode.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "aac-encode.js",
    "aac-encode.d.ts",
    "LICENSE",
    "audio.js",
    "audio.d.ts"
  ],
  "keywords": [
    "aac",
    "m4a",
    "adts",
    "audio",
    "encode",
    "encoder",
    "codec",
    "webcodecs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "audiojs",
  "homepage": "https://github.com/audiojs/encode/tree/main/packages/encode-aac",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/encode.git",
    "directory": "packages/encode-aac"
  },
  "engines": {
    "node": ">=18"
  },
  "bugs": "https://github.com/audiojs/encode/issues",
  "scripts": {
    "test": "node test.js"
  },
  "audio": "./audio.js"
