{
  "name": "@audio/encode-aiff",
  "version": "1.2.1",
  "description": "Encode PCM audio samples to AIFF format",
  "type": "module",
  "main": "aiff-encode.js",
  "types": "aiff-encode.d.ts",
  "exports": {
    ".": "./aiff-encode.js",
    "./meta": "./meta.js",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "aiff-encode.js",
    "aiff-encode.d.ts",
    "meta.js",
    "LICENSE",
    "audio.js",
    "audio.d.ts"
  ],
  "keywords": [
    "aiff",
    "audio",
    "encode",
    "encoder",
    "pcm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "audiojs",
  "homepage": "https://github.com/audiojs/encode/tree/main/packages/encode-aiff",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/encode.git",
    "directory": "packages/encode-aiff"
  },
  "engines": {
    "node": ">=18"
  },
  "bugs": "https://github.com/audiojs/encode/issues",
  "scripts": {
    "test": "node test.js"
  },
  "audio": "./audio.js",
  "sideEffects": false
}
